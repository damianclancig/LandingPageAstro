---
import '@/styles.css';
import { locales, siteConfig, type Locale } from '@/config/site';
import { buildDescription, buildKeywords } from '@/lib/metadata';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import MobileDrawer from '@/components/layout/MobileDrawer.astro';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  canonical?: string;
}

const { locale, title = siteConfig.name, description, canonical } = Astro.props;
const pageCanonical = canonical ?? `${siteConfig.url}/${locale}`;
const pageDescription = description ?? buildDescription(locale);
const pageKeywords = buildKeywords(locale);
const pageLocale = siteConfig.localeMap[locale] ?? siteConfig.localeMap.es;
const alternateOgLocales = locales
  .filter((entry: Locale) => entry !== locale)
  .map((entry: Locale) => siteConfig.localeMap[entry]);

const schemaData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteConfig.url}/#website`,
      "url": siteConfig.url,
      "name": siteConfig.name,
      "alternateName": ["Clancig", "Damián Clancig", "Clancig FullstackDev"],
      "publisher": {
        "@id": `${siteConfig.url}/#person`
      },
      "inLanguage": locale
    },
    {
      "@type": "ProfilePage",
      "@id": `${pageCanonical}/#profilepage`,
      "url": pageCanonical,
      "name": title,
      "description": pageDescription,
      "inLanguage": locale,
      "mainEntity": {
        "@id": `${siteConfig.url}/#person`
      }
    },
    {
      "@type": "Person",
      "@id": `${siteConfig.url}/#person`,
      "name": siteConfig.owner,
      "jobTitle": "Full-Stack Developer",
      "url": siteConfig.url,
      "image": siteConfig.ogImage,
      "sameAs": [
        "https://github.com/damianclancig",
        "https://linkedin.com/in/damianclancig",
        "https://instagram.com/damianclancig"
      ]
    }
  ]
});
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      (() => {
        const storageKey = 'theme-preference';
        const saved = window.localStorage.getItem(storageKey);
        const theme = saved === 'light' || saved === 'dark' || saved === 'system' ? saved : 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolvedTheme = theme === 'system' ? (prefersDark ? 'dark' : 'light') : theme;
        document.documentElement.classList.toggle('dark', resolvedTheme === 'dark');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <link rel="icon" type="image/png" href="/images/favicon_circular.png" />
    <link rel="icon" type="image/webp" href="/images/favicon_circular.webp" />
    <link rel="apple-touch-icon" href="/images/favicon_circular.png" />
    <link rel="shortcut icon" href="/images/favicon_circular.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta name="author" content={siteConfig.owner} />
    <meta name="application-name" content={siteConfig.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#09090b" />
    <link rel="canonical" href={pageCanonical} />
    <link rel="alternate" hreflang="es" href={`${siteConfig.url}/es`} />
    <link rel="alternate" hreflang="en" href={`${siteConfig.url}/en`} />
    <link rel="alternate" hreflang="pt" href={`${siteConfig.url}/pt`} />
    <link rel="alternate" hreflang="x-default" href={`${siteConfig.url}/es`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:image" content={siteConfig.ogImage} />
    <meta property="og:image:secure_url" content={siteConfig.ogImage} />
    <meta property="og:image:type" content={siteConfig.ogImageType} />
    <meta property="og:image:width" content={siteConfig.ogImageWidth} />
    <meta property="og:image:height" content={siteConfig.ogImageHeight} />
    <meta property="og:image:alt" content={siteConfig.ogImageAlt} />
    <meta property="og:locale" content={pageLocale} />
    {alternateOgLocales.map((entry: string) => <meta property="og:locale:alternate" content={entry} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitterSite} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={siteConfig.ogImage} />
    <meta name="twitter:image:alt" content={siteConfig.ogImageAlt} />
    <meta name="twitter:creator" content={siteConfig.twitterCreator} />
    <script type="application/ld+json" set:html={schemaData} />
  </head>
  <body>
    <div class="noise-pattern" aria-hidden="true"></div>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
    <MobileDrawer locale={locale} />
  </body>
</html>
